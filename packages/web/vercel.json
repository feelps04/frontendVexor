{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm install --ignore-scripts && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://api-felipe-coelhos-projects.vercel.app/api/:path*"
    },
    {
      "source": "/python-api/:path*",
      "destination": "https://api-felipe-coelhos-projects.vercel.app/python-api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}